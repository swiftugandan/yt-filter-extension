{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-vibe-pitfalls.sh",
            "timeout": 10,
            "statusMessage": "Checking for vibe coding pitfalls..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-vibe-pitfalls.sh",
            "timeout": 10,
            "statusMessage": "Checking for vibe coding pitfalls..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-vibe-pitfalls.sh",
            "timeout": 10,
            "statusMessage": "Checking for vibe coding pitfalls..."
          }
        ]
      }
    ]
  }
}
