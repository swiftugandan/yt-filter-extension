{
  "manifest_version": 3,
  "name": "YT Video Filter",
  "version": "2.1.0",
  "description": "Remove YouTube video containers matching custom filter criteria. Regex + ML-powered classification.",
  "permissions": ["storage", "activeTab", "tabs", "offscreen"],
  "host_permissions": ["*://*.youtube.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
